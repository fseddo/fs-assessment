{
  "name": "fs-assessment-backend",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript + Express API server with ping echo endpoint and Swagger UI.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "NODE_ENV=production node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/swagger-ui-express": "^4.1.6",
    "tsx": "^4.19.2",
    "typescript": "^5.5.3"
  }
}
